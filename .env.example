# ============================================================
# Seat Booking Application - Environment Variables
# Copy this file to .env and update values as needed.
# ============================================================

# ------------------------------------------------------------
# Backend Configuration
# ------------------------------------------------------------

# The port the backend API server listens on
API_PORT=8080

# Full PostgreSQL connection string for the backend
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?sslmode=disable
DATABASE_URL=postgresql://user:password@db:5432/booking_db?sslmode=disable

# Node environment (development | production)
NODE_ENV=production

# ------------------------------------------------------------
# Database Configuration (used by Docker Compose)
# ------------------------------------------------------------

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=booking_db

# ------------------------------------------------------------
# Frontend Configuration
# ------------------------------------------------------------

# Base URL for API calls. Leave empty when the frontend is
# served behind an Nginx reverse proxy (default Docker setup).
# Set to http://localhost:8080 for local development outside Docker.
REACT_APP_API_URL=

# The default show UUID to display seats for
REACT_APP_SHOW_ID=a0eebc99-9c0b-4ef8-bb6d-6bb9bd380a11
